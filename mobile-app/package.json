{
  "name": "fuel-path-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/leaflet": "^1.9.21",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-intent-launcher": "~56.0.4",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "leaflet": "^1.9.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "playwright": "^1.61.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "xcode": {
      "uuid": "^11.1.1"
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "doctor": "npm_config_cache=.npm-cache npx expo-doctor",
    "test": "npm run typecheck && npm run perf:deps && npm run arch:screens && npm run test:source-contracts && npm run test:native-api-contracts && npm run test:map-camera && npm run test:settings-ux && npm run test:route-evidence-copy",
    "smoke:plan-fields": "node scripts/smoke-plan-fields.mjs",
    "stress:plan-fields": "node scripts/stress-plan-fields.mjs",
    "stress:settings-flows": "node scripts/stress-settings-flows.mjs",
    "stress:nearby-settings": "FUEL_PATH_NEARBY_STRESS_CASES=${FUEL_PATH_NEARBY_STRESS_CASES:-100} FUEL_PATH_SETTINGS_STRESS_CASES=${FUEL_PATH_SETTINGS_STRESS_CASES:-100} node scripts/stress-nearby-settings.mjs",
    "stress:nearby-settings:high": "FUEL_PATH_NEARBY_STRESS_CASES=300 FUEL_PATH_SETTINGS_STRESS_CASES=300 node scripts/stress-nearby-settings.mjs",
    "stress:route-notification-schedule": "node scripts/stress-route-notification-schedule.mjs",
    "audit:station-brands": "node scripts/audit-station-brand-coverage.mjs",
    "sync:discounts": "node scripts/sync-discount-registry.mjs",
    "build:web": "npm run sync:discounts && node scripts/clean-web-export.mjs && EXPO_PUBLIC_FUEL_PATH_API_BASE_URL=__SAME_ORIGIN__ npm_config_cache=.npm-cache npx expo export --platform web --output-dir dist",
    "budget:size": "node scripts/check-bundle-budget.mjs",
    "budget:web": "node scripts/check-bundle-budget.mjs --scope=web",
    "budget:web:regression": "node scripts/check-web-bundle-regression.mjs",
    "budget:assets": "node scripts/check-bundle-budget.mjs --scope=assets",
    "budget:native": "node scripts/check-bundle-budget.mjs --scope=native",
    "arch:screens": "node scripts/check-screen-complexity.mjs",
    "verify": "npm test && npm run build:web && npm run budget:size",
    "native:preflight": "npm_config_cache=.npm-cache npx eas-cli env:exec preview 'npm run native:preflight:local' --non-interactive",
    "native:preflight:local": "node scripts/native-validation-preflight.mjs --strict",
    "native:preflight:preview": "npm run native:preflight",
    "native:readiness": "node scripts/native-device-readiness.mjs",
    "native:android-physical-readiness": "node scripts/native-device-readiness.mjs --strict --require-physical-android",
    "native:android-avd-plan": "node scripts/native-android-avd-plan.mjs",
    "native:android-map-smoke": "node scripts/native-android-map-smoke.mjs",
    "native:android-local-standalone": "node scripts/build-android-local-standalone.mjs",
    "native:android-preview-smoke": "node scripts/native-android-preview-smoke.mjs",
    "native:android-cold-start-smoke": "node scripts/native-android-cold-start-smoke.mjs",
    "native:android-performance-smoke": "node scripts/native-android-preview-smoke.mjs --require-physical --map-settle-ms 10000",
    "native:android-performance-summary": "node scripts/native-android-performance-summary.mjs",
    "native:android-performance-coverage": "node scripts/native-android-performance-coverage.mjs",
    "native:android-notification-readiness": "node scripts/native-android-notification-readiness.mjs",
    "native:android-alert-sync-smoke": "node scripts/native-android-alert-sync-smoke.mjs",
    "native:android-alert-delivery-gate": "node scripts/native-android-alert-delivery-gate.mjs",
    "native:android-navigation-intents": "node scripts/native-android-navigation-intents.mjs",
    "native:android-maps-key-fix": "node scripts/android-maps-key-fix-packet.mjs",
    "native:blocker-packet": "node scripts/native-blocker-packet.mjs",
    "native:ios-simulator-plan": "node scripts/native-ios-simulator-plan.mjs",
    "native:ios-validation-report": "node scripts/native-ios-validation-report.mjs",
    "native:evidence-audit": "node scripts/native-current-evidence-audit.mjs",
    "native:ios-ipad-free-smoke": "node scripts/native-ios-ipad-free-smoke.mjs",
    "native:ios-cold-start-smoke": "node scripts/native-ios-cold-start-smoke.mjs",
    "eas:preview:android": "npm_config_cache=.npm-cache npx eas-cli build --profile preview --platform android",
    "eas:preview:ios": "npm_config_cache=.npm-cache npx eas-cli build --profile preview --platform ios",
    "baseline:eas": "node scripts/record-preview-baseline.mjs",
    "perf:deps": "npm ls --depth=0",
    "test:map-camera": "node scripts/check-map-camera-guards.mjs",
    "test:source-contracts": "node --test ../tests/mobile/map-marker-state-guard.test.js ../tests/mobile/plan-autocomplete-session-guard.test.js ../tests/mobile/native-validation-preflight.test.js ../tests/mobile/web-export-clean.test.js ../tests/mobile/web-bundle-boundaries.test.js",
    "test:native-api-contracts": "node scripts/check-native-api-contracts.mjs",
    "test:settings-ux": "node scripts/check-settings-ux-guards.mjs",
    "test:route-evidence-copy": "node scripts/check-route-evidence-copy-guards.mjs",
    "typecheck": "npm run sync:discounts && tsc --noEmit",
    "native:map-geocode-parity": "node scripts/native-map-geocode-parity-check.mjs"
  },
  "private": true
}
