{
  "name": "fuel-path-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/leaflet": "^1.9.21",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "leaflet": "^1.9.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "playwright": "^1.61.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "xcode": {
      "uuid": "^11.1.1"
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "npm_config_cache=.npm-cache npx expo-doctor",
    "test": "npm run typecheck && npm run perf:deps && npm run arch:screens && npm run test:map-camera",
    "smoke:plan-fields": "node scripts/smoke-plan-fields.mjs",
    "stress:plan-fields": "node scripts/stress-plan-fields.mjs",
    "build:web": "EXPO_PUBLIC_FUEL_PATH_API_BASE_URL=__SAME_ORIGIN__ npm_config_cache=.npm-cache npx expo export --platform web --output-dir dist",
    "budget:size": "node scripts/check-bundle-budget.mjs",
    "budget:native": "node scripts/check-bundle-budget.mjs",
    "arch:screens": "node scripts/check-screen-complexity.mjs",
    "verify": "npm test && npm run build:web && npm run budget:size",
    "native:preflight": "npm_config_cache=.npm-cache npx eas-cli env:exec preview 'npm run native:preflight:local' --non-interactive",
    "native:preflight:local": "node scripts/native-validation-preflight.mjs --strict",
    "native:preflight:preview": "npm run native:preflight",
    "native:readiness": "node scripts/native-device-readiness.mjs",
    "native:android-physical-readiness": "node scripts/native-device-readiness.mjs --strict --require-physical-android",
    "native:android-avd-plan": "node scripts/native-android-avd-plan.mjs",
    "native:android-map-smoke": "node scripts/native-android-map-smoke.mjs",
    "native:android-preview-smoke": "node scripts/native-android-preview-smoke.mjs",
    "native:android-cold-start-smoke": "node scripts/native-android-cold-start-smoke.mjs",
    "native:android-performance-smoke": "node scripts/native-android-preview-smoke.mjs --require-physical --map-settle-ms 10000",
    "native:android-performance-summary": "node scripts/native-android-performance-summary.mjs",
    "native:android-maps-key-fix": "node scripts/android-maps-key-fix-packet.mjs",
    "native:blocker-packet": "node scripts/native-blocker-packet.mjs",
    "native:ios-simulator-plan": "node scripts/native-ios-simulator-plan.mjs",
    "native:ios-validation-report": "node scripts/native-ios-validation-report.mjs",
    "native:evidence-audit": "node scripts/native-current-evidence-audit.mjs",
    "native:ios-cold-start-smoke": "node scripts/native-ios-cold-start-smoke.mjs",
    "eas:preview:android": "npm_config_cache=.npm-cache npx eas-cli build --profile preview --platform android",
    "eas:preview:ios": "npm_config_cache=.npm-cache npx eas-cli build --profile preview --platform ios",
    "baseline:eas": "node scripts/record-preview-baseline.mjs",
    "perf:deps": "npm ls --depth=0",
    "test:map-camera": "node scripts/check-map-camera-guards.mjs",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
