# Copy this file to prototype/.env and fill in values locally.
# Do not paste secrets into chat.

NSW_FUEL_API_KEY=
NSW_FUEL_API_SECRET=

# Defaults can stay empty unless API.NSW support provides updated URLs.
NSW_FUEL_TOKEN_URL=https://api.onegov.nsw.gov.au/oauth/client_credential/accesstoken
NSW_FUEL_PRICES_URL=https://api.onegov.nsw.gov.au/FuelPriceCheck/v1/fuel/prices
