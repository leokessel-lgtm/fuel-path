# Copy this file to prototype/.env and fill in values locally.
# Do not paste secrets into chat.

NSW_FUEL_API_KEY=
NSW_FUEL_API_SECRET=

# Defaults can stay empty unless API.NSW support provides updated URLs.
NSW_FUEL_TOKEN_URL=https://api.onegov.nsw.gov.au/oauth/client_credential/accesstoken
NSW_FUEL_PRICES_URL=https://api.onegov.nsw.gov.au/FuelPriceCheck/v1/fuel/prices

# NSW/ACT FuelCheck public production switch.
# Keep unset until API.NSW confirms app/commercial usage, caching and attribution terms.
FUEL_PATH_NSW_ACT_USAGE_TERMS_CONFIRMED=

# TAS uses API.NSW Fuel API v2 through the same credentials.
# Keep unset until API.NSW/FuelCheck TAS confirms public usage, caching and attribution terms.
FUEL_PATH_TAS_USAGE_TERMS_CONFIRMED=

# Queensland Fuel Prices Direct Outbound API.
QLD_FUEL_API_BASE_URL=https://fppdirectapi-prod.fuelpricesqld.com.au
QLD_FUEL_API_TOKEN=

# Keep unset until QLD usage, caching and attribution terms are confirmed for public/commercial use.
FUEL_PATH_QLD_USAGE_TERMS_CONFIRMED=

# Hosted backend cache. Keep this high enough to avoid provider overuse.
FUEL_PATH_LIVE_CACHE_SECONDS=300

# Geocoding provider selection:
# auto uses Google, Mapbox, HERE or Geoapify if configured, otherwise Nominatim validation fallback.
FUEL_PATH_GEOCODE_PROVIDER=auto
FUEL_PATH_GOOGLE_PLACES_API_KEY=
FUEL_PATH_GEOCODE_QUOTA_DATABASE_URL=
FUEL_PATH_MAPBOX_ACCESS_TOKEN=
FUEL_PATH_HERE_API_KEY=
FUEL_PATH_GEOAPIFY_API_KEY=

# Route provider selection:
# auto uses Google Routes if configured, otherwise OSRM validation fallback.
FUEL_PATH_ROUTE_PROVIDER=auto
FUEL_PATH_GOOGLE_ROUTES_API_KEY=

# Optional shared Google Maps Platform key. Prefer the narrower keys above in production.
FUEL_PATH_GOOGLE_MAPS_API_KEY=
