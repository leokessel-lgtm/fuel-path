{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo \"No install required for static Fuel Path demo\"",
  "buildCommand": "sh scripts/build-vercel-static.sh",
  "outputDirectory": "public",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
